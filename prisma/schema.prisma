generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TeamMember {
  id              String       @id @default(uuid())
  name            String
  role            String
  location        String?
  bio             String
  yearsExperience Int?         @default(0)
  profileImageUrl String?
  skills          Skill[]
  socialLinks     SocialLink[]
  projects        Project[]    @relation("TeamMemberProjects")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Skill {
  id           String     @id @default(uuid())
  name         String
  category     String?    // e.g. Frontend, Backend, Tools
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id           String     @id @default(uuid())
  platform     String     // e.g. LinkedIn, GitHub
  url          String
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
}

model Project {
  id           String       @id @default(uuid())
  title        String
  shortDesc    String
  description  String
  category     String?
  challenge    String?
  solution     String?
  liveUrl      String?
  githubUrl    String?
  imageUrl     String?
  technologies String       // Comma separated string for simplicity
  results      String       // JSON snippet or comma separated
  members      TeamMember[] @relation("TeamMemberProjects")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model SiteSetting {
  id    String @id
  value String
}
